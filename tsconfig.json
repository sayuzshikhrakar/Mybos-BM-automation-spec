{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["./node_modules/@types"],
    "types": ["node", "mocha"],
    "baseUrl": ".",
    "paths": {
      "@wdio/globals": ["./node_modules/@wdio/globals/build/index.d.ts"],
      "@wdio/types": ["./node_modules/@wdio/types/build/index.d.ts"]
    },
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "wdio.conf.ts"],
  "exclude": ["node_modules"]
}
