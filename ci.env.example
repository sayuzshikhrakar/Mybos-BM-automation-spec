# ============================================================
# ci.env.example
# Copy to .env for local CI simulation
# All values MUST be set as GitHub Actions secrets in production
# ============================================================

# Device Farm / Appium Remote Server
DEVICE_FARM_URL=http://your-device-farm-host:4723/wd/hub
APPIUM_SERVER_URL=http://localhost:4723

# Execution Limits
RETRY_LIMIT=3
PARALLEL_INSTANCES=2

# Feature Flags
ENABLE_QUARANTINE=true
ENABLE_TELEMETRY=true

# Platform Target (android | ios)
PLATFORM=android

# App Under Test
APP_PATH=./apps/app-debug.apk
APP_BUNDLE_ID=com.your.app.bundle

# Device Configuration
DEVICE_NAME=emulator-5554
PLATFORM_VERSION=13.0

# Reporting
ALLURE_RESULTS_DIR=allure-results
REPORTS_DIR=reports
SCREENSHOTS_DIR=screenshots
